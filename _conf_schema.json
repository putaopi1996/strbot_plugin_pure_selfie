{
  "minimal_selfie": {
    "description": "群聊 LLM 自拍最小模式",
    "type": "object",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用插件",
        "default": true
      },
      "enabled_groups": {
        "type": "list",
        "description": "生效群号列表",
        "hint": "只在这些群聊里监听自然语言消息，并判断是否需要生成自拍。",
        "default": []
      },
      "preset_prompt": {
        "type": "string",
        "description": "预制提示词",
        "hint": "会和 LLM 从群消息里补全出的提示词一起拼接后发送给生图模型。",
        "default": "realistic phone selfie, natural skin texture, candid composition, single person, no collage, no text overlay, no watermark"
      },
      "reference_image_urls": {
        "type": "list",
        "description": "参考图 URL 列表",
        "hint": "直接填写图床地址，不需要上传。所有 URL 都会被当作同一身份的参考图。",
        "default": []
      },
      "api_base_url": {
        "type": "string",
        "description": "OpenAI 兼容接口地址",
        "hint": "例如 https://api.example.com/v1 或具体的 /v1/chat/completions 根地址。",
        "default": ""
      },
      "model": {
        "type": "string",
        "description": "生图模型",
        "default": ""
      },
      "api_token": {
        "type": "string",
        "description": "API 令牌",
        "default": ""
      },
      "image_size": {
        "type": "string",
        "description": "输出尺寸",
        "options": [
          "1024x1024",
          "1536x1024",
          "1024x1536",
          "2048x2048"
        ],
        "default": "1024x1024"
      },
      "group_rules": {
        "type": "template_list",
        "description": "群级规则",
        "hint": "按北京时间 00:00 重置。每个群可以单独配置每日次数和超限提示词。",
        "templates": {
          "group_rule": {
            "name": "群规则",
            "items": {
              "group_id": {
                "type": "string",
                "description": "群号",
                "default": ""
              },
              "daily_limit": {
                "type": "int",
                "description": "每日自拍上限",
                "hint": "只统计成功生成并发出的次数。0 表示不限制。",
                "default": 0
              },
              "limit_reject_prompt": {
                "type": "string",
                "description": "超限提示词",
                "hint": "超过每日上限后，不再生图，而是把这段提示词交给当前 LLM 生成一条自然婉拒消息。",
                "default": ""
              }
            }
          }
        }
      }
    }
  }
}
