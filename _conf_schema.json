{
  "minimal_selfie": {
    "description": "群聊 LLM 自拍最小模式",
    "type": "object",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用插件",
        "default": true
      },
      "enabled_groups": {
        "type": "list",
        "description": "生效群号列表",
        "hint": "只在这些群聊里监听自然语言消息，并判断是否需要生成自拍。",
        "default": []
      },
      "preset_prompt": {
        "type": "string",
        "description": "预制提示词",
        "hint": "会和 LLM 从群消息里补全出的提示词一起拼接后发送给生图模型。",
        "default": "realistic phone selfie, natural skin texture, candid composition, single person, no collage, no text overlay, no watermark"
      },
      "reference_images": {
        "type": "file",
        "description": "参考人像（可多张）",
        "hint": "建议上传清晰正脸照，可多张做不同角度参考。",
        "file_types": ["jpg", "jpeg", "png", "webp"],
        "default": []
      },
      "api_base_url": {
        "type": "string",
        "description": "接口地址",
        "hint": "普通 OpenAI 兼容服务可填 https://api.example.com/v1。Google 官方 Gemini 请填 https://generativelanguage.googleapis.com/v1beta 或 /v1beta/openai，插件会自动规范为 /openai。",
        "default": ""
      },
      "model": {
        "type": "string",
        "description": "生图模型",
        "default": ""
      },
      "api_token": {
        "type": "string",
        "description": "API 令牌",
        "default": ""
      },
      "image_size": {
        "type": "string",
        "description": "输出尺寸",
        "options": [
          "auto",
          "1024x1024",
          "1536x1024",
          "1024x1536",
          "2048x2048"
        ],
        "default": "auto"
      },
      "ignore_keywords": {
        "type": "list",
        "description": "排除关键词",
        "hint": "消息中包含任一关键词时，本插件完全不介入（不调用 LLM 判断、不触发生图）。用于避免和其他插件冲突。",
        "default": []
      },
      "group_rules": {
        "type": "template_list",
        "description": "群级规则",
        "hint": "按北京时间 00:00 重置。每个群可以单独配置每日次数和超限提示词。",
        "templates": {
          "group_rule": {
            "name": "群规则",
            "items": {
              "group_id": {
                "type": "string",
                "description": "群号",
                "default": ""
              },
              "daily_limit": {
                "type": "int",
                "description": "每日自拍上限",
                "hint": "只统计成功生成并发出的次数。0 表示不限制。",
                "default": 0
              },
              "limit_reject_prompt": {
                "type": "string",
                "description": "超限提示词",
                "hint": "超过每日上限后，不再生图，而是把这段提示词交给当前 LLM 生成一条自然婉拒消息。",
                "default": ""
              }
            }
          }
        }
      }
    }
  }
}
